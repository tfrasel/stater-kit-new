---
const { dashboard } = Astro.props;
---

<div class="w-full bg-[rgba(0,0,0,0.6)] backdrop-blur-3xl border border-[#1a382d] rounded-2xl overflow-hidden shadow-[0_0_80px_rgba(21,255,171,0.15)] flex flex-col xl:flex-row relative">

  <!-- Left Sidebar (Agents) -->
  <div class="w-full xl:w-[250px] bg-[rgba(255,255,255,0.02)] border-r border-white/5 flex flex-col relative shrink-0">
    <div class="absolute top-4 left-4 flex gap-1.5 opacity-50">
      <div class="w-3 h-3 rounded-full bg-red-500"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
      <div class="w-3 h-3 rounded-full bg-green-500"></div>
    </div>
    
    <div class="mt-14 px-6 flex items-center gap-3">
      <div class="w-8 h-8 rounded bg-[#15ffab]/10 text-[#15ffab] flex items-center justify-center font-bold text-lg">A</div>
      <span class="text-[#15ffab] font-medium text-lg tracking-wide">AgentFlow</span>
    </div>

    <div class="mt-10 px-4">
      <div class="bg-white/5 border border-white/10 rounded-xl p-4 flex flex-col gap-4">
        
        <div class="flex justify-between items-center bg-black/20 rounded p-2 border border-white/5">
           <div class="flex flex-col">
              <span class="text-xs font-bold uppercase tracking-wider text-gray-300">Agents</span>
              <span class="text-[10px] text-gray-500">{dashboard.agents.length} total</span>
           </div>
           <button class="bg-[#121212] border border-gray-700 text-xs px-3 py-1.5 rounded hover:bg-gray-800 transition">Add</button>
        </div>

        <div class="flex flex-col gap-2">
          {dashboard.agents.map((agent: any) => (
            <div class="flex items-center gap-3 bg-black/40 border border-white/5 p-3 rounded-lg hover:bg-black/60 transition cursor-pointer">
               <div class="w-8 h-8 rounded-full bg-[#202027] border border-gray-700 flex shrink-0 items-center justify-center relative">
                  <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                  <div class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border border-[#202027] rounded-full"></div>
               </div>
               <div class="flex flex-col overflow-hidden">
                 <span class="text-xs font-semibold text-gray-200 truncate">{agent.role}</span>
                 <span class="text-[10px] text-gray-500 truncate">{agent.type}</span>
               </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </div>

  <!-- Main View -->
  <div class="flex-1 flex flex-col min-h-[600px] overflow-hidden">
    <!-- Top Nav Layer -->
    <div class="border-b border-white/5 px-6 h-16 flex items-center justify-between">
       <div class="flex gap-4">
          <button class="bg-white/10 px-4 py-1.5 rounded-lg text-sm flex items-center gap-2 hover:bg-white/15 transition">
             <span class="w-2 h-2 rounded-full bg-blue-400"></span>
             Personal
          </button>
       </div>
       <div class="hidden md:flex bg-white/5 border border-white/10 px-4 py-2 rounded-full text-sm text-gray-400 w-64 items-center gap-2">
          <svg class="w-4 h-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          Search
       </div>
       <div class="flex items-center gap-3">
          <div class="flex flex-col items-end">
             <span class="text-xs font-bold text-gray-200">{dashboard.header.user.name}</span>
             <span class="text-[10px] text-gray-500">{dashboard.header.user.role}</span>
          </div>
          <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-purple-500 to-blue-500 p-0.5 relative">
             <div class="w-full h-full bg-black rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
             </div>
          </div>
       </div>
    </div>

    <!-- App Header & Filters -->
    <div class="px-6 py-4 flex items-center justify-between bg-black/20 border-b border-white/5">
       <div class="flex flex-col">
          <h2 class="text-xl font-bold tracking-tight text-gray-100">{dashboard.header.title}</h2>
          <span class="text-xs text-gray-400">{dashboard.header.subtitle}</span>
       </div>
       <div class="flex gap-2">
          <div class="flex bg-black border border-gray-800 rounded-lg p-1 overflow-hidden">
             <button class="bg-[#15ffab]/10 text-[#15ffab] px-3 py-1 rounded text-xs font-medium">Board</button>
             <button class="text-gray-500 px-3 py-1 rounded text-xs">List</button>
          </div>
          <button class="w-8 h-8 rounded-full bg-[#15ffab] text-black flex items-center justify-center hover:opacity-90 transition">
             +
          </button>
       </div>
    </div>

    <!-- Kanban Wrapper -->
    <div class="flex-1 overflow-x-auto p-6 scrollbar-hide">
      <div class="flex gap-6 min-w-max h-full">
         
         <!-- Columns Mapping -->
         {dashboard.columns.map((col: any, index: number) => (
           <div class="w-[280px] flex flex-col shrink-0 relative">
             <!-- Column Header -->
             <div class="flex items-center gap-3 mb-4">
                <div class="w-2 h-2 rounded-full" style={`background-color: ${col.color}`}></div>
                <span class="text-xs font-bold uppercase tracking-wider text-gray-200">{col.title}</span>
                <span class="bg-white/10 text-[10px] px-2 py-0.5 rounded-full text-gray-400">{col.count}</span>
             </div>

             <!-- Mock Cards -->
             <div class="flex flex-col gap-3">
               {[1, 2].map((i) => (
                 <div class={`bg-black/40 border border-white/5 p-4 rounded-xl flex flex-col gap-3 shadow-sm hover:border-white/10 hover:bg-black/60 transition ${index === 3 ? 'opacity-60 border-[#15ffab]/20' : ''}`}>
                    <p class="text-sm font-medium text-gray-200 leading-snug">
                       {index === 0 ? (i === 1 ? 'Customer Support Agent' : 'Data Analysis Bot') : ''}
                       {index === 1 ? (i === 1 ? 'Auto-route webhook leads via API' : 'Docs overhaul Phase 2') : ''}
                       {index === 2 ? (i === 1 ? 'Fix blocked task transitions 409' : 'Agent endpoint: read webhook payload') : ''}
                       {index === 3 ? (i === 1 ? 'Fix agent task patch auth' : 'Auth/Permissions: assigned agents 403') : ''}
                    </p>
                    <div class="flex justify-between items-center mt-2">
                       <span class={`text-[9px] uppercase px-2 py-1 rounded tracking-wider font-semibold 
                         ${i === 1 && index !== 3 ? 'bg-red-500/20 text-red-400' : 'bg-yellow-500/20 text-yellow-400'}`}>
                         {i === 1 && index !== 3 ? 'High' : 'Medium'}
                       </span>
                       <div class="flex gap-1">
                          <span class={`text-[9px] px-2 py-1 rounded bg-blue-500/10 text-blue-400 font-medium ${index === 2 ? 'bg-white/10 text-gray-400' : ''}`}>
                            {index === 2 ? 'Review' : 'AI'}
                          </span>
                       </div>
                    </div>
                 </div>
               ))}
             </div>
           </div>
         ))}
      </div>
    </div>

    <!-- Bottom Metrics Footer -->
    <div class="border-t border-white/5 px-6 py-4 flex flex-wrap xl:grid xl:grid-cols-4 gap-6 justify-between bg-black/40 mt-auto">
       {dashboard.metrics.map((metric: any) => (
         <div class="flex items-center gap-3">
             <div class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center shrink-0">
               <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
             </div>
             <div class="flex flex-col">
                <span class="text-lg font-bold text-gray-100">{metric.value}</span>
                <span class="text-[10px] text-gray-500 uppercase tracking-wide">{metric.label}</span>
             </div>
         </div>
       ))}
    </div>

    <!-- Absolute Accent Glow -->
    <div class="absolute bottom-[-100px] right-[-100px] w-64 h-64 bg-[#15ffab] rounded-full blur-[100px] opacity-10 pointer-events-none"></div>

  </div>
</div>
